# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# GROQ_API_KEY: Optional - Groq API for faster, cheaper AI processing.
# Get your key from https://console.groq.com/
# If provided, Groq will be used instead of Gemini for faster responses.
GROQ_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Paystack public key for payment processing
# Get your key from https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=

# Firebase Configuration (Public - Safe to expose in client-side code)
# These values are meant to be public. Security is handled by Firebase Security Rules.
# Get these from your Firebase project settings: https://console.firebase.google.com/
VITE_FIREBASE_CONFIG_API_KEY=
VITE_FIREBASE_CONFIG_AUTH_DOMAIN=
VITE_FIREBASE_CONFIG_PROJECT_ID=
VITE_FIREBASE_CONFIG_STORAGE_BUCKET=
VITE_FIREBASE_CONFIG_MESSAGING_SENDER_ID=
VITE_FIREBASE_CONFIG_APP_ID=
VITE_FIREBASE_CONFIG_MEASUREMENT_ID=

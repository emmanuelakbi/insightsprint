import React, { useState, useEffect } from "react";
import { motion, AnimatePresence } from "motion/react";
import {
  Search,
  Zap,
  Target,
  Users,
  ChevronRight,
  Loader2,
  ExternalLink,
  Info,
  ArrowRight,
  CheckCircle2,
  AlertCircle,
  Activity,
  Database,
  Cpu,
  FileText,
  History,
  LogOut,
  LogIn,
  Trash2,
  Clock,
} from "lucide-react";
import { ResearchReport, PipelineStep, PlanType, SavedResearch } from "./types";
import * as aiService from "./services/aiService";
import { auth, db, signInWithGoogle, logout } from "./firebase";
import {
  collection,
  addDoc,
  onSnapshot,
  query,
  where,
  orderBy,
  deleteDoc,
  doc,
  Timestamp,
  getDocFromServer,
} from "firebase/firestore";
import { onAuthStateChanged, User } from "firebase/auth";
import LandingPage from "./components/LandingPage";

const FREE_LIMIT = 20;
const PRO_LIMIT = 20;

enum OperationType {
  CREATE = "create",
  UPDATE = "update",
  DELETE = "delete",
  LIST = "list",
  GET = "get",
  WRITE = "write",
}

interface FirestoreErrorInfo {
  error: string;
  operationType: OperationType;
  path: string | null;
  authInfo: {
    userId: string | undefined;
    email: string | null | undefined;
    emailVerified: boolean | undefined;
    isAnonymous: boolean | undefined;
    tenantId: string | null | undefined;
    providerInfo: {
      providerId: string;
      displayName: string | null;
      email: string | null;
      photoUrl: string | null;
    }[];
  };
}

function handleFirestoreError(
  error: unknown,
  operationType: OperationType,
  path: string | null,
) {
  const errInfo: FirestoreErrorInfo = {
    error: error instanceof Error ? error.message : String(error),
    authInfo: {
      userId: auth.currentUser?.uid,
      email: auth.currentUser?.email,
      emailVerified: auth.currentUser?.emailVerified,
      isAnonymous: auth.currentUser?.isAnonymous,
      tenantId: auth.currentUser?.tenantId,
      providerInfo:
        auth.currentUser?.providerData.map((provider) => ({
          providerId: provider.providerId,
          displayName: provider.displayName,
          email: provider.email,
          photoUrl: provider.photoURL,
        })) || [],
    },
    operationType,
    path,
  };
  console.error("Firestore Error: ", JSON.stringify(errInfo));
  throw new Error(JSON.stringify(errInfo));
}

const PricingModal = ({
  isOpen,
  onClose,
  currentPlan,
  onUpgrade,
}: {
  isOpen: boolean;
  onClose: () => void;
  currentPlan: PlanType;
  onUpgrade: () => void;
}) => {
  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        onClick={onClose}
        className="absolute inset-0 bg-ink/80 backdrop-blur-sm"
      />
      <motion.div
        initial={{ scale: 0.9, opacity: 0, y: 20 }}
        animate={{ scale: 1, opacity: 1, y: 0 }}
        className="brutalist-card bg-white w-full max-w-2xl relative z-10 overflow-y-auto max-h-[90vh] md:max-h-none"
      >
        <div className="bg-ink text-white p-6 flex justify-between items-center">
          <h2 className="text-[clamp(1.2rem,5vw,2rem)] sm:text-3xl font-black uppercase tracking-tighter">
            Choose_Your_Plan
          </h2>
          <button
            onClick={onClose}
            className="hover:text-accent transition-colors shrink-0"
          >
            <AlertCircle className="w-8 h-8 rotate-45" />
          </button>
        </div>

        <div className="grid md:grid-cols-2 gap-0">
          {/* Free Plan */}
          <div className="p-8 border-b-4 md:border-b-0 md:border-r-4 border-ink">
            <div className="mb-8">
              <p className="text-[10px] font-black tracking-widest text-gray-400 uppercase mb-2">
                Basic_Access
              </p>
              <h3 className="text-4xl font-black mb-2">FREE</h3>
              <p className="text-sm font-bold text-gray-500 uppercase">
                For casual explorers.
              </p>
            </div>
            <ul className="space-y-4 mb-12">
              <li className="flex items-center gap-3 text-xs font-bold uppercase">
                <CheckCircle2 className="w-5 h-5 text-green-500" />3 Research
                Runs / Day
              </li>
              <li className="flex items-center gap-3 text-xs font-bold uppercase">
                <CheckCircle2 className="w-5 h-5 text-green-500" />
                Standard Reports
              </li>
              <li className="flex items-center gap-3 text-xs font-bold uppercase opacity-30">
                <AlertCircle className="w-5 h-5" />
                No Slide Export
              </li>
            </ul>
            <button
              disabled={currentPlan === "free"}
              className={`w-full brutalist-card py-4 text-sm font-black uppercase tracking-widest ${currentPlan === "free" ? "bg-gray-100 text-gray-400 cursor-not-allowed" : "hover:bg-accent hover:text-white transition-all"}`}
            >
              {currentPlan === "free" ? "Current_Plan" : "Select_Free"}
            </button>
          </div>

          {/* Pro Plan */}
          <div className="p-8 bg-accent/5">
            <div className="mb-8">
              <p className="text-[10px] font-black tracking-widest text-accent uppercase mb-2">
                Professional_Grade
              </p>
              <h3 className="text-4xl font-black mb-2">PRO</h3>
              <p className="text-sm font-bold text-gray-500 uppercase">
                For founders & analysts.
              </p>
            </div>
            <ul className="space-y-4 mb-12">
              <li className="flex items-center gap-3 text-xs font-bold uppercase">
                <CheckCircle2 className="w-5 h-5 text-accent" />
                20 Research Runs / Day
              </li>
              <li className="flex items-center gap-3 text-xs font-bold uppercase">
                <CheckCircle2 className="w-5 h-5 text-accent" />
                Deep Intelligence Reports
              </li>
              <li className="flex items-center gap-3 text-xs font-bold uppercase">
                <CheckCircle2 className="w-5 h-5 text-accent" />
                Export Slide Outlines
              </li>
              <li className="flex items-center gap-3 text-xs font-bold uppercase">
                <CheckCircle2 className="w-5 h-5 text-accent" />
                Priority Processing
              </li>
            </ul>
            <button
              onClick={() =>
                alert(
                  "PRO Plan Coming Soon! Enjoy the current features for free.",
                )
              }
              className={`w-full brutalist-button py-4 text-sm font-black uppercase tracking-widest bg-gray-100 text-gray-400 cursor-not-allowed`}
            >
              Coming_Soon
            </button>
            <p className="text-[10px] font-bold text-center mt-4 text-gray-400 uppercase">
              * Pro features are currently enabled for all users
            </p>
          </div>
        </div>
      </motion.div>
    </div>
  );
};

const HistorySidebar = ({
  isOpen,
  onClose,
  history,
  onSelect,
  onDelete,
}: {
  isOpen: boolean;
  onClose: () => void;
  history: SavedResearch[];
  onSelect: (item: SavedResearch) => void;
  onDelete: (id: string, e: React.MouseEvent) => void;
}) => {
  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 z-[100] flex justify-end">
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        onClick={onClose}
        className="absolute inset-0 bg-ink/60 backdrop-blur-sm"
      />
      <motion.div
        initial={{ x: "100%" }}
        animate={{ x: 0 }}
        exit={{ x: "100%" }}
        className="brutalist-card bg-white w-full max-w-full sm:max-w-md relative z-10 h-full overflow-hidden flex flex-col"
      >
        <div className="bg-ink text-white p-6 flex justify-between items-center">
          <h2 className="text-[clamp(1.1rem,4vw,1.5rem)] sm:text-2xl font-black uppercase tracking-tighter flex items-center gap-3">
            <History className="w-6 h-6 shrink-0" />
            RESEARCH_HISTORY
          </h2>
          <button
            onClick={onClose}
            className="hover:text-accent transition-colors shrink-0"
          >
            <AlertCircle className="w-8 h-8 rotate-45" />
          </button>
        </div>

        <div className="flex-1 overflow-y-auto p-6 space-y-4">
          {history.length === 0 ? (
            <div className="text-center py-20">
              <Clock className="w-12 h-12 text-gray-200 mx-auto mb-4" />
              <p className="text-xs font-bold text-gray-400 uppercase">
                No_History_Found
              </p>
            </div>
          ) : (
            history.map((item) => (
              <div
                key={item.id}
                onClick={() => onSelect(item)}
                className="brutalist-card p-4 hover:bg-accent/5 cursor-pointer group relative"
              >
                <div className="flex justify-between items-start mb-2">
                  <span className="text-[10px] font-black bg-ink text-white px-2 py-0.5 uppercase">
                    {item.mode}
                  </span>
                  <button
                    onClick={(e) => onDelete(item.id, e)}
                    className="text-gray-300 hover:text-accent transition-colors"
                  >
                    <Trash2 className="w-4 h-4" />
                  </button>
                </div>
                <h4 className="text-sm font-black uppercase leading-tight mb-2 line-clamp-2">
                  {item.goal}
                </h4>
                <p className="text-[10px] font-bold text-gray-400 uppercase">
                  {new Date(item.createdAt).toLocaleDateString()} @{" "}
                  {new Date(item.createdAt).toLocaleTimeString()}
                </p>
              </div>
            ))
          )}
        </div>
      </motion.div>
    </div>
  );
};

const TEMPLATES = [
  {
    id: "market_landscape",
    label: "MARKET LANDSCAPE",
    icon: Target,
    goal: "I want to understand the current state of the GenAI-powered developer tools market in 2026.",
    color: "border-ink hover:bg-accent hover:text-white",
  },
  {
    id: "competitor_analysis",
    label: "COMPETITOR ANALYSIS",
    icon: Users,
    goal: "Analyze the top 3 competitors in the AI-driven personal finance space for Gen Z.",
    color: "border-ink hover:bg-accent hover:text-white",
  },
  {
    id: "hackathon_scouting",
    label: "HACKATHON SCOUTING",
    icon: Zap,
    goal: "Find upcoming GenAI hackathons in Europe for Spring 2026 and identify key themes.",
    color: "border-ink hover:bg-accent hover:text-white",
  },
];

const INITIAL_STEPS: PipelineStep[] = [
  { id: "plan", label: "01_PLANNING", status: "idle" },
  { id: "gather", label: "02_GATHERING", status: "idle" },
  { id: "synthesize", label: "03_SYNTHESIS", status: "idle" },
  { id: "next_steps", label: "04_STRATEGY", status: "idle" },
];

export default function App() {
  const [goal, setGoal] = useState("");
  const [keywords, setKeywords] = useState("");
  const [mode, setMode] = useState<ResearchReport["mode"]>("custom");
  const [loading, setLoading] = useState(false);
  const [steps, setSteps] = useState<PipelineStep[]>(INITIAL_STEPS);
  const [report, setReport] = useState<ResearchReport | null>(null);
  const [error, setError] = useState<string | null>(null);

  // Auth & History State
  const [user, setUser] = useState<User | null>(null);
  const [isAuthReady, setIsAuthReady] = useState(false);
  const [isLoggingIn, setIsLoggingIn] = useState(false);
  const [history, setHistory] = useState<SavedResearch[]>([]);
  const [showHistory, setShowHistory] = useState(false);

  // Subscription State
  const [plan, setPlan] = useState<PlanType>("free");
  const [runCount, setRunCount] = useState(() => {
    const saved = localStorage.getItem("run_count");
    return saved ? parseInt(saved, 10) : 0;
  });
  const [showPricing, setShowPricing] = useState(false);
  const [showLanding, setShowLanding] = useState(true);
  const [selectedModel, setSelectedModel] = useState("gemini-2.0-flash");

  // Test Connection
  useEffect(() => {
    async function testConnection() {
      try {
        await getDocFromServer(doc(db, "test", "connection"));
      } catch (error) {
        if (
          error instanceof Error &&
          error.message.includes("the client is offline")
        ) {
          console.error("Please check your Firebase configuration. ");
        }
      }
    }
    testConnection();
  }, []);

  // Auth Listener
  useEffect(() => {
    const unsubscribe = onAuthStateChanged(auth, (u) => {
      setUser(u);
      setIsAuthReady(true);
    });
    return () => unsubscribe();
  }, []);

  // History Listener
  useEffect(() => {
    if (!user || !isAuthReady) {
      setHistory([]);
      return;
    }

    const q = query(
      collection(db, "research_history"),
      where("uid", "==", user.uid),
      orderBy("createdAt", "desc"),
    );

    const unsubscribe = onSnapshot(
      q,
      (snapshot) => {
        const items = snapshot.docs.map((doc) => ({
          id: doc.id,
          ...doc.data(),
        })) as SavedResearch[];
        setHistory(items);
      },
      (error) => {
        handleFirestoreError(error, OperationType.LIST, "research_history");
      },
    );

    return () => unsubscribe();
  }, [user, isAuthReady]);

  useEffect(() => {
    localStorage.setItem("run_count", runCount.toString());
  }, [runCount]);

  useEffect(() => {
    if (user) {
      setIsLoggingIn(false);
    }
  }, [user]);

  const handleLogin = async () => {
    if (isLoggingIn) return;
    setIsLoggingIn(true);

    // Safety timeout: if login takes more than 30 seconds, reset the state
    // This handles cases where the popup might be blocked or hang without throwing
    const timer = setTimeout(() => {
      setIsLoggingIn(false);
    }, 30000);

    try {
      await signInWithGoogle();
    } catch (err: any) {
      if (err.code === "auth/cancelled-popup-request") {
        console.log("Login popup request was cancelled by a newer request.");
      } else if (err.code === "auth/popup-closed-by-user") {
        console.log("Login popup was closed by the user.");
      } else {
        console.error("Login error:", err);
        setError(err.message || "Failed to login");
      }
    } finally {
      clearTimeout(timer);
      setIsLoggingIn(false);
    }
  };

  const runResearch = async () => {
    if (!goal.trim()) return;

    // Check limits
    const limit = plan === "pro" ? PRO_LIMIT : FREE_LIMIT;
    if (runCount >= limit) {
      setError(
        `RUN_LIMIT_EXCEEDED: You have used all ${limit} runs for your ${plan.toUpperCase()} plan. Upgrade to Pro for more.`,
      );
      setShowPricing(true);
      return;
    }

    setLoading(true);
    setReport(null);
    setError(null);

    const newSteps = INITIAL_STEPS.map((s) => ({
      ...s,
      status: "idle" as const,
    }));
    setSteps(newSteps);

    try {
      // Step 1: Planning
      updateStep("plan", "loading");
      const planData = await aiService.planResearch(goal, mode, selectedModel);
      updateStep("plan", "done");

      // Step 2: Gathering
      updateStep("gather", "loading");
      const snippets = await aiService.fetchPages(
        goal,
        planData.searchQueries,
        selectedModel,
      );
      updateStep("gather", "done");

      // Step 3: Synthesis
      updateStep("synthesize", "loading");
      const data = await aiService.synthesizeReport(
        goal,
        mode,
        planData,
        snippets,
        plan,
        selectedModel,
      );
      updateStep("synthesize", "done");

      // Step 4: Next Steps
      updateStep("next_steps", "loading");
      setTimeout(async () => {
        updateStep("next_steps", "done");
        setReport(data);
        setLoading(false);
        setRunCount((prev) => prev + 1);

        // Save to History if logged in
        if (user) {
          try {
            await addDoc(collection(db, "research_history"), {
              uid: user.uid,
              goal: goal,
              mode: mode,
              createdAt: new Date().toISOString(),
              report: data,
            });
          } catch (err) {
            handleFirestoreError(err, OperationType.CREATE, "research_history");
          }
        }
      }, 1000);
    } catch (err: any) {
      console.error("Research error:", err);
      setError(err.message || "An unexpected error occurred during research.");
      setLoading(false);
      setSteps((s) =>
        s.map((step) =>
          step.status === "loading" ? { ...step, status: "error" } : step,
        ),
      );
    }
  };

  const deleteHistoryItem = async (id: string, e: React.MouseEvent) => {
    e.stopPropagation();
    try {
      await deleteDoc(doc(db, "research_history", id));
    } catch (err) {
      handleFirestoreError(err, OperationType.DELETE, `research_history/${id}`);
    }
  };

  const updateStep = (id: string, status: PipelineStep["status"]) => {
    setSteps((prev) => prev.map((s) => (s.id === id ? { ...s, status } : s)));
  };

  const applyTemplate = (template: (typeof TEMPLATES)[0]) => {
    setGoal(template.goal);
    setMode(template.id as ResearchReport["mode"]);
  };

  if (showLanding) {
    return <LandingPage onEnter={() => setShowLanding(false)} />;
  }

  return (
    <div className="min-h-screen p-4 sm:p-8 overflow-x-hidden">
      {/* Grid Overlay for Aesthetic */}
      <div className="fixed inset-0 pointer-events-none border-[16px] border-ink/5 z-[-1]" />

      {/* Header */}
      <header className="max-w-6xl mx-auto mb-8 sm:mb-16 flex flex-col md:flex-row justify-between items-start md:items-end gap-4 border-b-4 border-ink pb-6">
        <div className="w-full md:w-auto">
          <div className="flex flex-wrap items-center justify-between md:justify-start gap-2 mb-4">
            <div className="flex items-center gap-3">
              <Activity className="text-accent w-8 h-8" />
              <span className="text-xs font-bold tracking-widest bg-ink text-white px-2 py-0.5">
                V2.0_STABLE
              </span>
            </div>

            <div className="flex items-center gap-3">
              <div className="flex items-center gap-2">
                <span
                  className={`text-[10px] font-black px-2 py-0.5 border-2 border-ink uppercase ${plan === "pro" ? "bg-accent text-white" : "bg-white text-ink"}`}
                >
                  Plan: {plan}
                </span>
                {plan === "free" && (
                  <button
                    onClick={() => setShowPricing(true)}
                    className="text-[10px] font-black text-accent hover:underline uppercase tracking-widest"
                  >
                    [Upgrade]
                  </button>
                )}
              </div>

              {user ? (
                <div className="flex flex-wrap items-center gap-2 border-l-2 border-ink pl-3">
                  <button
                    onClick={() => setShowHistory(true)}
                    className="flex items-center gap-2 text-[10px] font-black uppercase hover:text-accent transition-colors"
                  >
                    <History className="w-4 h-4" />
                    History
                  </button>
                  <button
                    onClick={logout}
                    className="flex items-center gap-2 text-[10px] font-black uppercase hover:text-accent transition-colors"
                  >
                    <LogOut className="w-4 h-4" />
                    Logout
                  </button>
                  {user.photoURL && (
                    <img
                      src={user.photoURL}
                      alt="Profile"
                      className="w-6 h-6 border-2 border-ink"
                      referrerPolicy="no-referrer"
                    />
                  )}
                </div>
              ) : (
                <button
                  onClick={handleLogin}
                  disabled={isLoggingIn}
                  className={`flex items-center gap-2 text-[10px] font-black uppercase bg-accent text-white px-3 py-1 border-2 border-ink hover:bg-ink transition-colors ${isLoggingIn ? "opacity-50 cursor-not-allowed" : ""}`}
                >
                  {isLoggingIn ? (
                    <Loader2 className="w-4 h-4 animate-spin" />
                  ) : (
                    <LogIn className="w-4 h-4" />
                  )}
                  {isLoggingIn ? "Logging_In..." : "Login_To_Save"}
                </button>
              )}
            </div>
          </div>
          <h1 className="text-[clamp(1.2rem,6vw,4.5rem)] font-extrabold leading-none">
            INSIGHT<span className="text-accent">SPRINT</span>
          </h1>
        </div>
        <div className="text-right hidden sm:block">
          <p className="text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">
            GENAI_ZURICH_HACKATHON_2026
          </p>
          <div className="flex flex-col items-end">
            <p className="text-sm font-medium max-w-xs">
              AUTOMATED MARKET INTELLIGENCE & AGENTIC RESEARCH PIPELINE.
            </p>
            <p className="text-[10px] font-bold text-accent mt-2 uppercase tracking-widest">
              Usage: {runCount} / {plan === "pro" ? PRO_LIMIT : FREE_LIMIT} Runs
              Used
            </p>
          </div>
        </div>
      </header>

      <main className="max-w-6xl mx-auto">
        <div className="grid lg:grid-cols-[1fr_360px] gap-8 xl:gap-12 items-start">
          {/* Left Column: Input & Results */}
          <div className="space-y-8 sm:space-y-12">
            {/* Input Section */}
            <section className="brutalist-card p-4 sm:p-8 relative overflow-hidden">
              <div className="absolute top-0 right-0 bg-ink text-white px-4 py-1 text-[10px] font-bold tracking-widest uppercase">
                Input_Module
              </div>

              <div className="flex flex-wrap gap-2 mb-8">
                {TEMPLATES.map((t) => (
                  <button
                    key={t.id}
                    onClick={() => applyTemplate(t)}
                    className={`brutalist-card px-4 py-2 text-[10px] font-bold tracking-widest transition-all active:scale-95 ${t.color}`}
                  >
                    {t.label}
                  </button>
                ))}
              </div>

              <div className="space-y-6">
                <div>
                  <label className="block text-[10px] font-bold uppercase tracking-widest mb-2 text-gray-500">
                    [01] RESEARCH_GOAL_SPECIFICATION
                  </label>
                  <textarea
                    value={goal}
                    onChange={(e) => setGoal(e.target.value)}
                    placeholder="DEFINE RESEARCH PARAMETERS..."
                    className="brutalist-input w-full h-40 resize-none text-xl font-bold uppercase placeholder:text-gray-200"
                  />
                </div>

                <div className="grid sm:grid-cols-[1fr_200px] gap-4">
                  <div>
                    <label className="block text-[10px] font-bold uppercase tracking-widest mb-2 text-gray-500">
                      [02] CONTEXTUAL_KEYWORDS
                    </label>
                    <input
                      type="text"
                      value={keywords}
                      onChange={(e) => setKeywords(e.target.value)}
                      placeholder="TAGS_DOMAINS_ETC"
                      className="brutalist-input w-full text-sm font-bold uppercase"
                    />
                  </div>
                  <button
                    onClick={runResearch}
                    disabled={loading || !goal.trim()}
                    className="brutalist-button h-full flex items-center justify-center gap-3"
                  >
                    {loading ? (
                      <Loader2 className="w-6 h-6 animate-spin" />
                    ) : (
                      <Search className="w-6 h-6" />
                    )}
                    RUN_PROC
                  </button>
                </div>
              </div>
            </section>

            {/* Error State */}
            {error && (
              <motion.div
                initial={{ x: -20, opacity: 0 }}
                animate={{ x: 0, opacity: 1 }}
                className="bg-accent text-white p-6 border-2 border-ink shadow-[4px_4px_0px_0px_rgba(18,18,18,1)] flex items-center gap-4"
              >
                <AlertCircle className="w-8 h-8 shrink-0" />
                <div>
                  <p className="text-xs font-bold uppercase tracking-widest opacity-80 mb-1">
                    SYSTEM_ERROR
                  </p>
                  <p className="text-lg font-bold uppercase leading-tight">
                    {error}
                  </p>
                </div>
              </motion.div>
            )}

            {/* Results Section */}
            <AnimatePresence>
              {report && (
                <motion.div
                  initial={{ opacity: 0, y: 40 }}
                  animate={{ opacity: 1, y: 0 }}
                  className="space-y-12"
                >
                  {/* Overview */}
                  <div className="brutalist-card p-4 sm:p-8 relative">
                    <div className="absolute -top-3 -left-3 bg-accent text-white px-3 py-1 text-[10px] font-bold tracking-widest border-2 border-ink">
                      01_OVERVIEW
                    </div>
                    <div className="prose prose-invert max-w-none">
                      <p className="text-lg sm:text-xl font-bold leading-tight uppercase mb-0">
                        {report.overview}
                      </p>
                    </div>
                  </div>

                  {/* Insights & Risks Grid */}
                  <div className="grid md:grid-cols-2 gap-6 sm:gap-8">
                    <div className="brutalist-card p-4 sm:p-8 border-l-[12px] border-l-ink">
                      <h4 className="text-[clamp(1.1rem,4vw,1.5rem)] sm:text-2xl font-black mb-6 flex items-center gap-3 break-all">
                        <Database className="w-6 h-6 text-accent" />
                        KEY_INSIGHTS
                      </h4>
                      <ul className="space-y-6">
                        {report.keyInsights.map((insight, i) => (
                          <motion.li
                            initial={{ opacity: 0, x: -10 }}
                            animate={{ opacity: 1, x: 0 }}
                            transition={{ delay: i * 0.1 }}
                            key={i}
                            className="flex gap-4"
                          >
                            <span className="text-accent font-bold">
                              [{String(i + 1).padStart(2, "0")}]
                            </span>
                            <span className="text-sm font-bold uppercase leading-snug">
                              {insight}
                            </span>
                          </motion.li>
                        ))}
                      </ul>
                    </div>

                    <div className="brutalist-card p-4 sm:p-8 border-l-[12px] border-l-accent">
                      <h4 className="text-[clamp(1.1rem,4vw,1.5rem)] sm:text-2xl font-black mb-6 flex items-center gap-3 break-all">
                        <AlertCircle className="w-6 h-6 text-accent" />
                        RISKS_GAPS
                      </h4>
                      <ul className="space-y-6">
                        {report.risksAndGaps.map((risk, i) => (
                          <motion.li
                            initial={{ opacity: 0, x: -10 }}
                            animate={{ opacity: 1, x: 0 }}
                            transition={{ delay: i * 0.1 }}
                            key={i}
                            className="flex gap-4"
                          >
                            <span className="text-ink font-bold">
                              [{String(i + 1).padStart(2, "0")}]
                            </span>
                            <span className="text-sm font-bold uppercase leading-snug">
                              {risk}
                            </span>
                          </motion.li>
                        ))}
                      </ul>
                    </div>
                  </div>

                  {/* Next Steps */}
                  <div className="brutalist-card bg-ink text-white p-4 sm:p-8">
                    <h4 className="text-[clamp(1.2rem,5vw,2rem)] sm:text-3xl font-black mb-8 flex items-center gap-4 break-all">
                      <ArrowRight className="w-8 h-8 text-accent" />
                      STRATEGIC_NEXT_STEPS
                    </h4>
                    <div className="grid sm:grid-cols-2 gap-6">
                      {report.nextSteps.map((step, i) => (
                        <div
                          key={i}
                          className="border-2 border-white/20 p-6 hover:border-accent transition-colors group"
                        >
                          <p className="text-xs font-bold text-accent mb-2 group-hover:translate-x-1 transition-transform">
                            ACTION_ITEM_{i + 1}
                          </p>
                          <p className="text-sm font-bold uppercase leading-relaxed">
                            {step}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Slide Outline Bonus */}
                  {report.slideOutline && (
                    <div className="brutalist-card p-4 sm:p-8 border-t-[12px] border-t-accent relative overflow-hidden">
                      {plan === "free" && (
                        <div className="absolute inset-0 z-10 bg-white/60 backdrop-blur-[2px] flex flex-col items-center justify-center p-8 text-center">
                          <div className="bg-ink text-white p-6 brutalist-card max-w-sm">
                            <Zap className="w-12 h-12 text-accent mx-auto mb-4" />
                            <h5 className="text-2xl font-black mb-2 uppercase">
                              PRO_FEATURE_LOCKED
                            </h5>
                            <p className="text-sm font-bold uppercase mb-6 opacity-80">
                              Upgrade to Pro to unlock deep slide outlines and
                              export capabilities.
                            </p>
                            <button
                              onClick={() => setShowPricing(true)}
                              className="w-full brutalist-button py-3 text-sm font-black uppercase tracking-widest"
                            >
                              Upgrade_Now
                            </button>
                          </div>
                        </div>
                      )}
                      <h4 className="text-[clamp(1.2rem,5vw,2rem)] sm:text-3xl font-black mb-8 flex items-center gap-4 break-all">
                        <FileText className="w-8 h-8 text-accent" />
                        PITCH_DECK_OUTLINE
                      </h4>
                      <div className="space-y-8">
                        {report.slideOutline.slides.map((slide, i) => (
                          <div
                            key={i}
                            className="border-b-2 border-ink/5 pb-6 last:border-0"
                          >
                            <h5 className="text-lg font-black mb-4 text-accent">
                              SLIDE_{String(i + 1).padStart(2, "0")}:{" "}
                              {slide.title}
                            </h5>
                            <ul className="space-y-2">
                              {slide.bullets.map((bullet, j) => (
                                <li
                                  key={j}
                                  className="flex gap-3 text-sm font-bold uppercase"
                                >
                                  <span className="text-gray-300">/</span>
                                  {bullet}
                                </li>
                              ))}
                            </ul>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* Sources */}
                  <div className="brutalist-card p-4 sm:p-8">
                    <h4 className="text-[clamp(1.2rem,5vw,2rem)] font-black mb-6 sm:mb-8 break-all">
                      VERIFIED_SOURCES
                    </h4>
                    <div className="grid sm:grid-cols-2 gap-4">
                      {report.sources.map((source, i) => (
                        <a
                          key={i}
                          href={source.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="brutalist-card p-4 hover:bg-paper transition-colors group"
                        >
                          <div className="flex items-center justify-between mb-2">
                            <span className="font-black text-sm uppercase truncate pr-4">
                              {source.title}
                            </span>
                            <ExternalLink className="w-4 h-4 shrink-0 group-hover:text-accent" />
                          </div>
                          <p className="text-[10px] font-bold text-gray-400 truncate mb-2">
                            {source.url}
                          </p>
                          {source.note && (
                            <p className="text-[11px] font-medium uppercase italic text-gray-600 border-t border-gray-100 pt-2">
                              REF: {source.note}
                            </p>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                </motion.div>
              )}
            </AnimatePresence>
          </div>

          {/* Right Column: Pipeline & Info */}
          <aside className="grid sm:grid-cols-2 lg:grid-cols-1 gap-6 lg:gap-8 items-start">
            {/* Pipeline Status */}
            <div className="brutalist-card p-6">
              <h3 className="text-xl font-black mb-6 border-b-2 border-ink pb-2">
                PIPELINE_STATUS
              </h3>
              <div className="space-y-8">
                {steps.map((step, idx) => (
                  <div key={step.id} className="relative">
                    <div className="flex items-center gap-4">
                      <div
                        className={`w-10 h-10 border-2 border-ink flex items-center justify-center font-black text-sm transition-all ${
                          step.status === "done"
                            ? "bg-green-500 text-white"
                            : step.status === "loading"
                              ? "bg-accent text-white animate-pulse"
                              : step.status === "error"
                                ? "bg-red-500 text-white"
                                : "bg-white text-ink"
                        }`}
                      >
                        {step.status === "done" ? (
                          <CheckCircle2 className="w-6 h-6" />
                        ) : step.status === "error" ? (
                          <AlertCircle className="w-6 h-6" />
                        ) : (
                          String(idx + 1).padStart(2, "0")
                        )}
                      </div>
                      <div>
                        <p
                          className={`text-xs font-black tracking-widest ${step.status === "idle" ? "text-gray-300" : "text-ink"}`}
                        >
                          {step.label}
                        </p>
                        {step.status === "loading" && (
                          <div className="h-1 w-24 bg-gray-100 mt-1 relative overflow-hidden">
                            <motion.div
                              className="absolute inset-0 bg-accent"
                              animate={{ x: [-100, 100] }}
                              transition={{
                                repeat: Infinity,
                                duration: 1,
                                ease: "linear",
                              }}
                            />
                          </div>
                        )}
                      </div>
                    </div>
                    {idx < steps.length - 1 && (
                      <div className="absolute left-5 top-10 w-[2px] h-8 bg-ink/10" />
                    )}
                  </div>
                ))}
              </div>

              <div className="mt-12 pt-8 border-t-2 border-ink">
                <h4 className="text-xs font-black tracking-widest mb-4 flex items-center gap-2">
                  <Cpu className="w-4 h-4" />
                  SYSTEM_SPECS
                </h4>
                <div className="space-y-2 text-[10px] font-bold text-gray-500 uppercase">
                  <div className="flex justify-between items-center">
                    <span>MODEL_CORE</span>
                    <select
                      value={selectedModel}
                      onChange={(e) => setSelectedModel(e.target.value)}
                      className="text-ink bg-white border-2 border-ink px-1 py-0.5 text-[10px] font-black uppercase cursor-pointer hover:bg-accent hover:text-white transition-colors"
                    >
                      <option value="gemini-2.0-flash">GEMINI_2.0_FLASH</option>
                      <option value="gemini-2.0-flash-lite">
                        GEMINI_2.0_FLASH_LITE
                      </option>
                      <option value="gemini-1.5-flash">GEMINI_1.5_FLASH</option>
                      <option value="gemini-1.5-pro">GEMINI_1.5_PRO</option>
                      <option value="llama-3.3-70b-versatile">GROQ_LLAMA_3.3_70B</option>
                      <option value="gemini-2.5-pro-preview-06-05">
                        GEMINI_2.5_PRO
                      </option>
                    </select>
                  </div>
                  <div className="flex justify-between">
                    <span>AGENT_TYPE</span>
                    <span className="text-ink">MULTI_STEP_PLANNER</span>
                  </div>
                  <div className="flex justify-between">
                    <span>LATENCY</span>
                    <span className="text-ink">~6.5S_AVG</span>
                  </div>
                </div>
              </div>
            </div>

            {/* How it works */}
            <div className="brutalist-card p-6 bg-accent text-white">
              <h3 className="text-lg font-black mb-4 flex items-center gap-2">
                <FileText className="w-5 h-5" />
                TECH_STACK
              </h3>
              <p className="text-[11px] font-bold uppercase leading-relaxed opacity-90">
                INSIGHTSPRINT ORCHESTRATES A THREE-PHASE AGENTIC WORKFLOW:
                <br />
                <br />
                [01] PLANNER DECONSTRUCTS GOALS INTO ATOMIC QUERIES.
                <br />
                <br />
                [02] SCRAPER EXTRACTS HIGH-DENSITY DATA SNIPPETS.
                <br />
                <br />
                [03] SYNTHESIZER RECONSTRUCTS RAW DATA INTO STRATEGIC
                INTELLIGENCE.
              </p>
            </div>
          </aside>
        </div>
      </main>

      {/* Footer */}
      <footer className="max-w-6xl mx-auto mt-16 border-t-4 border-ink py-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left">
        <div className="flex items-center gap-3">
          <Activity className="text-accent w-6 h-6" />
          <span className="text-2xl font-black">INSIGHTSPRINT</span>
        </div>
        <div className="flex flex-wrap justify-center sm:justify-start gap-4 sm:gap-8 text-[10px] font-black tracking-widest text-gray-400">
          <button
            onClick={() => setShowPricing(true)}
            className="hover:text-accent"
          >
            PLANS_&_PRICING
          </button>
          <a href="#" className="hover:text-accent">
            TERMINAL_ACCESS
          </a>
          <a href="#" className="hover:text-accent">
            API_DOCS
          </a>
          <a href="#" className="hover:text-accent">
            PRIVACY_POLICY
          </a>
        </div>
        <p className="text-[10px] font-bold text-gray-500 uppercase">
          COPYRIGHT_2026_INSIGHTSPRINT_LABS
        </p>
      </footer>

      <AnimatePresence>
        {showPricing && (
          <PricingModal
            isOpen={showPricing}
            onClose={() => setShowPricing(false)}
            currentPlan={plan}
            onUpgrade={() => {}}
          />
        )}
        {showHistory && (
          <HistorySidebar
            isOpen={showHistory}
            onClose={() => setShowHistory(false)}
            history={history}
            onSelect={(item) => {
              setReport(item.report);
              setGoal(item.goal);
              setMode(item.mode as ResearchReport["mode"]);
              setShowHistory(false);
            }}
            onDelete={deleteHistoryItem}
          />
        )}
      </AnimatePresence>
    </div>
  );
}
